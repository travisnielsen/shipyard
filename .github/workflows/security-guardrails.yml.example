name: Security Guardrails

on:
  push:
    branches:
      - main
  pull_request:
  workflow_dispatch:

jobs:
  guardrails:
    name: Passwordless Workspace Guardrails
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Verify password-based auth is not reintroduced
        shell: bash
        run: |
          set -euo pipefail

          echo "Checking for forbidden password-based workspace auth patterns..."

          if rg -n --hidden --glob '!**/.git/**' 'DEVCONTAINER_PASSWORD' devcontainer infra; then
            echo "ERROR: DEVCONTAINER_PASSWORD references are forbidden."
            exit 1
          fi

          if rg -n --hidden --glob '!**/.git/**' -- '--auth[[:space:]]+password' devcontainer infra; then
            echo "ERROR: Password auth mode references are forbidden."
            exit 1
          fi

          if rg -n --hidden --glob '!**/.git/**' 'code-server.*--auth' devcontainer infra; then
            echo "ERROR: code-server auth flags were detected; workspace auth must remain identity-based."
            exit 1
          fi

          echo "Checking storage key retrieval is limited to ACA provisioning script..."

          KEY_RETRIEVAL_MATCHES="$(rg -n --hidden --glob '!**/.git/**' \
            'az[[:space:]]+storage[[:space:]]+account[[:space:]]+keys[[:space:]]+list' \
            devcontainer infra .github || true)"

          if [[ -n "${KEY_RETRIEVAL_MATCHES}" ]]; then
            DISALLOWED_MATCHES="$(printf '%s\n' "${KEY_RETRIEVAL_MATCHES}" | \
              rg -v '^devcontainer/scripts/provision-workspace-aca\.sh:' || true)"

            if [[ -n "${DISALLOWED_MATCHES}" ]]; then
              echo "ERROR: Storage key retrieval command is only allowed in devcontainer/scripts/provision-workspace-aca.sh"
              echo "Disallowed occurrences:"
              printf '%s\n' "${DISALLOWED_MATCHES}"
              exit 1
            fi
          fi

          echo "Security guardrails passed."
