#!/usr/bin/env bash
# pre-push: Blocks direct pushes to protected branches (main, master).
# Developers must work on feature branches and merge via pull request.

set -euo pipefail

PROTECTED_BRANCHES="^(main|master)$"

while read -r _local_ref _local_sha _remote_ref _remote_sha; do
  BRANCH="$(echo "$_remote_ref" | sed 's|refs/heads/||')"
  if echo "$BRANCH" | grep -qE "$PROTECTED_BRANCHES"; then
    echo ""
    echo "❌  Direct push to '$BRANCH' is not allowed."
    echo ""
    echo "    '$BRANCH' is a protected branch. Please:"
    echo "      1. Create a feature branch:  git checkout -b feat/<your-feature>"
    echo "      2. Push your branch:         git push origin feat/<your-feature>"
    echo "      3. Open a pull request to merge into $BRANCH."
    echo ""
    exit 1
  fi
done

exit 0
